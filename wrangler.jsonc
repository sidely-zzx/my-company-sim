{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "web-cad",
  "compatibility_date": "2026-06-25",
  "assets": {
    // SPA 现在只需要部署 Vite 产出的静态文件，不再走 SSR Worker 入口。
    "directory": "./dist",
    // 让 /game、/settings 这类前端路由在 Cloudflare 上回退到 index.html。
    "not_found_handling": "single-page-application"
  }
}
